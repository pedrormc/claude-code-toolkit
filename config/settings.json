{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75",
    "ECC_HOOK_PROFILE": "strict"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/scripts/claude-notify.js\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/scripts/claude-notify.js\"",
            "timeout": 10000,
            "async": true
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-end-memory-writer.sh",
            "timeout": 10000,
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/obsidian-auto-save.sh",
            "timeout": 15000
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/scripts/claude-notify.js\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/scripts/claude-notify.js\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/scripts/claude-notify.js\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\033]0;Claude Code - Trabalhando...\\007' > /dev/tty 2>/dev/null || true",
            "timeout": 2000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/verify-ecc-patches.sh",
            "timeout": 3000,
            "async": false
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start-memory-loader.sh",
            "timeout": 10000,
            "async": true
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "any-buddy apply --silent",
            "async": true,
            "timeout": 30000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-edit-memory-validator.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/save-session-vault-mirror.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh",
    "padding": 1
  },
  "enabledPlugins": {
    "everything-claude-code@everything-claude-code": true,
    "superpowers@superpowers-marketplace": true,
    "ralph-skills@ralph-marketplace": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "example-skills@anthropic-agent-skills": true,
    "vercel@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "everything-claude-code": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "ralph-marketplace": {
      "source": {
        "source": "github",
        "repo": "snarktank/ralph"
      }
    },
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "github",
        "repo": "nextlevelbuilder/ui-ux-pro-max-skill"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "theme": "light",
  "skipAutoPermissionPrompt": true,
  "skillOverrides": {
    "everything-claude-code:cpp-coding-standards": "off",
    "everything-claude-code:cpp-testing": "off",
    "everything-claude-code:perl-patterns": "off",
    "everything-claude-code:perl-security": "off",
    "everything-claude-code:perl-testing": "off",
    "everything-claude-code:swift-concurrency-6-2": "off",
    "everything-claude-code:swift-actor-persistence": "off",
    "everything-claude-code:swift-protocol-di-testing": "off",
    "everything-claude-code:swiftui-patterns": "off",
    "everything-claude-code:foundation-models-on-device": "off",
    "everything-claude-code:kotlin-coroutines-flows": "off",
    "everything-claude-code:compose-multiplatform-patterns": "off",
    "everything-claude-code:android-clean-architecture": "off",
    "everything-claude-code:kotlin-reviewer": "off",
    "everything-claude-code:golang-patterns": "off",
    "everything-claude-code:golang-testing": "off",
    "everything-claude-code:go-build": "off",
    "everything-claude-code:go-review": "off",
    "everything-claude-code:go-test": "off",
    "everything-claude-code:go-build-resolver": "off",
    "everything-claude-code:go-reviewer": "off",
    "everything-claude-code:java-coding-standards": "off",
    "everything-claude-code:jpa-patterns": "off",
    "everything-claude-code:springboot-tdd": "off",
    "everything-claude-code:springboot-verification": "off",
    "everything-claude-code:springboot-security": "off",
    "everything-claude-code:springboot-patterns": "off",
    "everything-claude-code:gradle-build": "off",
    "everything-claude-code:django-tdd": "off",
    "everything-claude-code:django-verification": "off",
    "everything-claude-code:django-security": "off",
    "everything-claude-code:django-patterns": "off",
    "everything-claude-code:python-testing": "user-invocable-only",
    "everything-claude-code:python-patterns": "user-invocable-only",
    "everything-claude-code:python-review": "user-invocable-only",
    "everything-claude-code:python-reviewer": "user-invocable-only",
    "everything-claude-code:clickhouse-io": "off",
    "everything-claude-code:customs-trade-compliance": "off",
    "everything-claude-code:energy-procurement": "off",
    "everything-claude-code:carrier-relationship-management": "off",
    "everything-claude-code:logistics-exception-management": "off",
    "everything-claude-code:returns-reverse-logistics": "off",
    "everything-claude-code:quality-nonconformance": "off",
    "everything-claude-code:production-scheduling": "off",
    "everything-claude-code:inventory-demand-planning": "off",
    "everything-claude-code:visa-doc-translate": "off",
    "everything-claude-code:videodb": "off",
    "everything-claude-code:plankton-code-quality": "off",
    "everything-claude-code:nutrient-document-processing": "off",
    "everything-claude-code:investor-outreach": "off",
    "everything-claude-code:investor-materials": "off"
  },
  "skillListingMaxDescChars": 200,
  "disabledPlugins": []
}
