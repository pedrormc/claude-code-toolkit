# ── Autenticacao (escolha UMA opcao) ──
#
# OPCAO 1 — Claude Max/Pro/Team (recomendado):
#   Deixe ANTHROPIC_API_KEY vazio. Depois do build, rode:
#   docker compose run --rm claude bash
#   E dentro do container: claude login
#
# OPCAO 2 — API Key (pay-per-use):
#   Pegue em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Workspace ──
# Diretorio do host que o Claude pode acessar (UNICO acesso ao host)
WORKSPACE_PATH=/home/admin/claude

# ── Optional: n8n integration ──
# N8N_API_URL=https://your-n8n-instance.com
# N8N_API_KEY=your-n8n-api-key

# ── Optional: headless mode ──
# CLAUDE_PROMPT="Review the codebase for security issues"
# CLAUDE_ALLOWED_TOOLS=Read,Glob,Grep,Bash,Edit,Write
